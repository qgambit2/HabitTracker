# Example env file — safe to commit. Copy to .env.local and fill in real values.
# See supabase/schema.sql for the database setup that pairs with these.
#
# Get these from the Supabase dashboard:
#   EXPO_PUBLIC_SUPABASE_URL      → Project Settings → API → Project URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY → Project Settings → API Keys → "anon public" key
#
# The anon key is publishable (RLS enforces per-user access). Do NOT use the
# service_role key or DB password in the client.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI coaching (Coach tab) — the Anthropic API key is a *server-side* secret used only by
# the `coach` Supabase Edge Function. It is NOT an EXPO_PUBLIC_ var and must never ship in
# the app bundle. Set it on the function, not here:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Then deploy:  supabase functions deploy coach
#
# Optional: the coach function only echoes CORS headers to browser origins on its
# allowlist (native apps send no Origin and are unaffected). localhost dev origins are
# allowed by default; add your deployed web origin(s) like so (comma-separated):
#   supabase secrets set COACH_ALLOWED_ORIGINS=https://your-web-app.example
