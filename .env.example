# Example env file — safe to commit. Copy to .env.local and fill in real values.
# See supabase/schema.sql for the database setup that pairs with these.
#
# Get these from the Supabase dashboard:
#   EXPO_PUBLIC_SUPABASE_URL      → Project Settings → API → Project URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY → Project Settings → API Keys → "anon public" key
#
# The anon key is publishable (RLS enforces per-user access). Do NOT use the
# service_role key or DB password in the client.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
